            local fuerzaEfectiva = math.clamp((150 - distancia) / 35, 0.2, 1.5)
            
            local offsetAleatorio = Vector3.new(
                math.random(-50, 50) * 0.007 * fuerzaEfectiva,
                math.random(-50, 50) * 0.007 * fuerzaEfectiva,
                math.random(-50, 50) * 0.007 * fuerzaEfectiva
            )
            local anguloAleatorio = CFrame.Angles(
                math.rad(math.random(-25, 25) * 0.015 * fuerzaEfectiva),
                math.rad(math.random(-25, 25) * 0.015 * fuerzaEfectiva),
                math.rad(math.random(-25, 25) * 0.015 * fuerzaEfectiva)
            )
            
            Camara.CFrame = Camara:GetRenderCFrame() * CFrame.new(offsetAleatorio) * anguloAleatorio
        end
    end
end)

task.spawn(function()
    while entidad and entidad.Parent do task.wait(0.2) end
