-- SCRIPT REBOUND - PARTE 3: APARICIÓN POR DELANTE Y OLEADAS POR PUERTA
-- ==========================================================
local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

local VELOCIDAD_ULTRA = 430 
local PASO_TIEMPO = 0.010 

-- NUEVAS IDS DE AUDIO
local AUDIO_ADVERTENCIA = "rbxassetid://14093035297"
local AUDIO_MOVIMIENTO = "rbxassetid://18920812603"

local currentRooms = workspace:FindFirstChild("CurrentRooms")
if not currentRooms then return end

if not _G.B35_Shared or not _G.B35_Shared.Entidad then
    error("Error: No se detectó el entorno físico de las fases previas.")
end

local entidad = _G.B35_Shared.Entidad

local function romperLucesDeHabitaciones()
    for _, sala in ipairs(currentRooms:GetChildren()) do
        if tonumber(sala.Name) then
            for _, objeto in ipairs(sala:GetDescendants()) do
                if objeto:IsA("Light") or objeto:IsA("PointLight") or objeto:IsA("SpotLight") or objeto:IsA("SurfaceLight") then
                    objeto.Enabled = false 
                elseif objeto:IsA("BasePart") and (objeto.Name:lower():find("light") or objeto.Name:lower():find("glass") or objeto.Name:lower():find("foco")) then
                    objeto.Material = Enum.Material.Plastic 
                    objeto.Color = Color3.fromRGB(40, 40, 40) 
                end
            end
        end
    end
end

-- Detección de apertura de puertas
local function obtenerUltimaSala()
    local numeroMaximo = -1
    local salaMasLejana = nil
    for _, sala in ipairs(currentRooms:GetChildren()) do
        local num = tonumber(sala.Name)
        if num and num > numeroMaximo then
            numeroMaximo = num
            salaMasLejana = sala
        end
    end
    return salaMasLejana, numeroMaximo
end

local function esperarNuevaPuerta(numeroSalaActual)
    while true do
        task.wait(0.2)
        local _, nuevoMaximo = obtenerUltimaSala()
        if nuevoMaximo and nuevoMaximo > numeroSalaActual then
            return nuevoMaximo
        end
    end
end

task.spawn(function()
    local pGui = localPlayer:WaitForChild("PlayerGui", 5)
	local contenedorAudio = pGui or workspace.CurrentCamera

    for pasada = 1, 3 do
        if not entidad or not entidad.Parent then break end

        -- Reproducir audio de advertencia antes de atacar
        local sonidoAdvertencia = Instance.new("Sound")
        sonidoAdvertencia.SoundId = AUDIO_ADVERTENCIA
        sonidoAdvertencia.Volume = 8 -- Volumen alto
        sonidoAdvertencia.Parent = contenedorAudio
        sonidoAdvertencia:Play()
        
        task.wait(2.5)
        if sonidoAdvertencia then sonidoAdvertencia:Destroy() end

        -- Audio de movimiento en bucle con volumen amplificado
        local soundMovimiento = Instance.new("Sound")
        soundMovimiento.SoundId = AUDIO_MOVIMIENTO
        soundMovimiento.Volume = 10 -- Volumen máximo
        soundMovimiento.Looped = true
        soundMovimiento.Parent = contenedorAudio
        soundMovimiento:Play()

        -- Colocar a Rebound al frente (En la última puerta abierta)
        local ultimaSala, ultimoNumero = obtenerUltimaSala()
        if ultimaSala then
            local puertaAlFrente = ultimaSala:FindFirstChild("Door") or ultimaSala:FindFirstChild("DoorPlatform") or ultimaSala:FindFirstChild("RoomStart")
            if puertaAlFrente then
                if puertaAlFrente:IsA("Model") then 
                    puertaAlFrente = puertaAlFrente.PrimaryPart or puertaAlFrente:FindFirstChildOfClass("BasePart") 
                end
                if puertaAlFrente then
                    entidad.CFrame = puertaAlFrente.CFrame * CFrame.new(0, 3, 0)
                end
            end
        end

        local function moverFisicamenteHacia(posicionDestino, esPuerta)
            local destinoAjustado = posicionDestino
            if not esPuerta then
                destinoAjustado = posicionDestino + Vector3.new(0, 3, 0)
            end
            
            while entidad and entidad.Parent do
                local posicionActual = entidad.Position
                local vectorDireccion = destinoAjustado - posicionActual
                local distanciaRestante = vectorDireccion.Magnitude
                local avancePorFotograma = VELOCIDAD_ULTRA * PASO_TIEMPO
                
                if distanciaRestante <= math.max(avancePorFotograma, 3.5) then break end
                
                local direccionNormalizada = vectorDireccion.Unit
                local nuevaPosicion = posicionActual + (direccionNormalizada * avancePorFotograma)
                
                local anguloY = _G.B35_Shared and _G.B35_Shared.Angulo or 0
                local offsetGlitch = _G.B35_Shared and _G.B35_Shared.Offset or Vector3.new(0,0,0)
                
                entidad.CFrame = CFrame.lookAt(nuevaPosicion, nuevaPosicion + direccionNormalizada) 
                                 * CFrame.Angles(0, math.rad(anguloY), 0) 
                                 * CFrame.new(offsetGlitch)
                
                task.wait(PASO_TIEMPO)
            end
        end

        -- Recorrido de habitaciones de Adelante hacia Atrás
        local salas = {}
        for _, obj in ipairs(currentRooms:GetChildren()) do
            if tonumber(obj.Name) then table.insert(salas, obj) end
        end
        
        -- Orden descendente (De adelante hacia atrás)
        table.sort(salas, function(a, b) return tonumber(a.Name) > tonumber(b.Name) end)
        
        for _, sala in ipairs(salas) do
            if not entidad or not entidad.Parent then break end
            
            if _G.B35_Shared and _G.B35_Shared.SoltarParticulas then
                _G.B35_Shared.SoltarParticulas(sala)
            end
            
            local rutaInterna = sala:FindFirstChild("Waypoints") or sala:FindFirstChild("Nodes") or sala:FindFirstChild("Path") or sala:FindFirstChild("Ruta")
            local nodosExistentes = {}
            
            if rutaInterna then
                for _, nodo in ipairs(rutaInterna:GetChildren()) do 
                    if nodo:IsA("BasePart") then 
                        table.insert(nodosExistentes, nodo) 
                    end 
                end
                
                table.sort(nodosExistentes, function(a, b)
                    local distA = (entidad.Position - a.Position).Magnitude
                    local distB = (entidad.Position - b.Position).Magnitude
                    return distA < distB
                end)
            end
            
            if #nodosExistentes > 0 then
                for _, nodo in ipairs(nodosExistentes) do 
                    moverFisicamenteHacia(nodo.Position, false) 
                end
            else
                local centroSala = sala:FindFirstChild("RoomStart") or sala:FindFirstChild("Floor") or sala:FindFirstChild("PrimaryPart")
                if centroSala and centroSala:IsA("BasePart") then moverFisicamenteHacia(centroSala.Position, false) end
            end
            
            local nodoPuerta = sala:FindFirstChild("Door") or sala:FindFirstChild("DoorPlatform")
            if nodoPuerta then
                if nodoPuerta:IsA("Model") then nodoPuerta = nodoPuerta.PrimaryPart or nodoPuerta:FindFirstChild("Door") or nodoPuerta:FindFirstChildOfClass("BasePart") end
                if nodoPuerta then moverFisicamenteHacia(nodoPuerta.Position, true) end
            end
        end

        soundMovimiento:Destroy()

        -- Ocultar entidad temporalmente mientras se abre la siguiente puerta
        entidad.Transparency = 1
        
        -- Si aún no ha completado las 3 pasadas, espera a que se abra la próxima puerta
        if pasada < 3 then
            local _, salaMaximaActual = obtenerUltimaSala()
            esperarNuevaPuerta(salaMaximaActual)
            entidad.Transparency = 1 -- Se mantiene listo para atacar de nuevo
        end
    end

    romperLucesDeHabitaciones()

    if entidad then entidad:Destroy() end
    _G.B35_Shared = nil
    print("[SISTEMA] Rebound completó sus 3 pasadas desde el frente.")
end)
